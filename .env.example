# Required
TELEGRAM_BOT_TOKEN=
TELEGRAM_USER_ID=

# Optional (defaults shown)
MAX_TURNS=25
WORKING_DIRECTORY=~

# Bot identity (optional)
BOT_NAME=cogent42
BOT_PERSONALITY=

# Cross-bot knowledge fallback (multi-instance setups)
# Siblings are auto-discovered via ~/.cogent42/instances/. Set to "true" to opt out
# of both registration and fallback lookup.
DISABLE_KNOWLEDGE_FALLBACK=
